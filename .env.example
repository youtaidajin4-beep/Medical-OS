# Database
# ローカル（Docker Compose）:
DATABASE_URL="postgresql://medical_os:medical_os@localhost:5432/medical_os?schema=public"
# Staging / Production（Supabase 等）:
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/medical_os?schema=public&sslmode=require"

# Backend
PORT=3001
JWT_SECRET="change-me-in-production"
NODE_ENV=development
FRONTEND_URL="http://localhost:3000"

# Frontend
NEXT_PUBLIC_API_URL="http://localhost:3001"
NEXT_PUBLIC_DEMO_MODE=false

# Storage (PR4+)
STORAGE_PROVIDER=local
# local | minio
MINIO_ENDPOINT="localhost"
MINIO_PORT=9000
MINIO_ACCESS_KEY="minioadmin"
MINIO_SECRET_KEY="minioadmin"
MINIO_BUCKET="medical-os-audio"

# AI Providers (PR5+)
# Requires ffmpeg for multi-chunk recording: brew install ffmpeg
# OpenAI 実装時は両方 openai + OPENAI_API_KEY 必須（起動時に検証）
# パイロット（8/1）: openai を推奨
STT_PROVIDER=openai
# mock | openai
LLM_PROVIDER=openai
# mock | openai
OPENAI_API_KEY=
OPENAI_WHISPER_MODEL=whisper-1
OPENAI_LLM_MODEL=gpt-4o-mini
