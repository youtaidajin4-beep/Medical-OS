{
  "name": "medical-os",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "test": "turbo test",
    "typecheck": "turbo typecheck",
    "db:generate": "pnpm --filter @medical-os/backend db:generate",
    "db:migrate": "pnpm --filter @medical-os/backend db:migrate",
    "db:push": "pnpm --filter @medical-os/backend db:push",
    "db:seed": "pnpm --filter @medical-os/backend db:seed"
  },
  "devDependencies": {
    "turbo": "^2.3.4",
    "typescript": "^5.7.3"
  },
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=22"
  }
}
